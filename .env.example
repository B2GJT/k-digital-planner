# ─── API 제공자 선택 ──────────────────────────────────────────
# 값: anthropic | groq | openai
API_PROVIDER=anthropic

# ─── Anthropic (기본값, 웹서치 내장) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Groq (빠른 응답, 웹서치 미지원 → Tavily 필요) ────────────
GROQ_API_KEY=gsk_...
TAVILY_API_KEY=tvly-...   # Groq 사용 시 시장조사 기능에 필요

# ─── OpenAI (gpt-4o, 웹서치 내장) ────────────────────────────
OPENAI_API_KEY=sk-...
